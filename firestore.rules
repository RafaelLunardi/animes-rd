rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Coleções existentes (pending animes / suggest)
    match /pending_animes/{docId} {
      allow read, write: if request.auth != null;
    }
    match /animes/{docId} {
      allow read, write: if request.auth != null;
    }

    // Batalha de Animes — requer login Google
    match /battle_sessions_v2/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /battle_votes_v2/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
